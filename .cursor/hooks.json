{
  "version": 1,
  "hooks": {
    "stop": [
      {
        "command": "bash .cursor/hooks/stop-check-domain.sh",
        "timeout": 120,
        "loop_limit": 3
      }
    ],
    "beforeShellExecution": [
      {
        "command": "bash .cursor/hooks/block-destructive-shell.sh",
        "failClosed": true
      }
    ]
  }
}
